<section class="feedback" aria-label="Форма обратной связи">
  <details class="feedback-details">
    <summary class="feedback-toggle">Оставить отзыв, предложение или сообщить о баге, проблеме, ошибке разработчику</summary>

    <form
      class="feedback-form"
      name="feedback"
      netlify
    >
      <input type="hidden" name="form-name" value="feedback" />

      <label>
        Имя
        <input type="text" name="name" autocomplete="name" />
      </label>

      <label>
        Сообщение
        <textarea name="message" rows="4" required></textarea>
      </label>

      <button type="submit">Отправить</button>
    </form>
  </details>
</section>

<style>
  .feedback {
    margin-top: 2rem;
  }

  .feedback-form label {
    display: grid;
    gap: 0.35rem;
    color: var(--color-text-dim);
    font-size: 0.9rem;
  }

  .feedback-form input,
  .feedback-form textarea {
    width: 100%;
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    background: #141414;
    color: var(--color-text);
    padding: 0.65rem 0.75rem;
  }

  .feedback-form textarea {
    resize: vertical;
    min-height: 6rem;
  }
</style>