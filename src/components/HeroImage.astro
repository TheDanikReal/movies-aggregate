---
import { Image } from 'astro:assets';

interface Studio {
  id: number;
  logo_path: string | null;
  name: string;
  origin_country: string;
}

interface Movie {
  name: string;
  times: Record<string, string[]>;
  description: string;
  age: string;
  poster_link: string;
  backdrop_link: string;
  studio: Studio[];
}

interface Props {
  movies: Movie[];
}

const { movies } = Astro.props;

function selectHeroMovie(movies: Movie[]): Movie | null {
  const PREFERRED_STUDIOS = ['disney', 'pixar', 'marvel', 'dreamworks'];

  // Filter valid movies (not 18+, has backdrop)
  const validMovies = movies.filter(movie =>
    movie.age !== "18+" &&
    movie.backdrop_link &&
    movie.backdrop_link.trim() !== "" &&
    movie.studio &&
    Array.isArray(movie.studio)
  );

  if (validMovies.length === 0) return null;

  // Find movie with preferred studio
  const preferredMovie = validMovies.find(movie =>
    movie.studio.some(studio =>
      PREFERRED_STUDIOS.includes(studio.name.toLowerCase())
    )
  );

  // Return preferred or fallback to first valid
  return preferredMovie || validMovies[0];
}

const heroMovie = selectHeroMovie(movies);
---

{heroMovie && (
  <div class="hero-container">
    <Image
      src={heroMovie.backdrop_link}
      alt={`${heroMovie.name} backdrop`}
      loading="eager"
      inferSize={true}
      class="hero-image"
    />
    <div class="hero-gradient"></div>
    <div class="hero-movie-name">{heroMovie.name}</div>
  </div>
)}

<style>
  .hero-container {
    position: relative;
    width: 100vw;
    height: 30vh;
    margin: 0;
    margin-left: calc(-50vw + 50%);
    overflow: hidden;
    background: #0f0f0f;
  }

  .hero-image {
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: center;
  }

  .hero-gradient {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(
      to bottom,
      transparent 0%,
      rgba(15, 15, 15, 0.3) 50%,
      rgba(15, 15, 15, 0.7) 75%,
      #0f0f0f 100%
    );
    pointer-events: none;
  }

  .hero-movie-name {
    position: absolute;
    top: 1rem;
    right: 1rem;
    color: var(--color-text);
    font-size: 1.25rem;
    font-weight: bold;
    text-shadow: 2px 2px 8px rgba(0, 0, 0, 0.9);
    z-index: 10;
  }

  @media (min-width: 768px) {
    .hero-movie-name {
      font-size: 1.5rem;
      top: 1.5rem;
      right: 2rem;
    }
  }
</style>
