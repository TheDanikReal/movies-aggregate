---
import { Image } from 'astro:assets';
import fallback from './../../tools/moviefallback.webp'

interface Showtime {
  time: string;
  timestamp: string;
}

interface Movie {
  name: string;
  times: Record<string, Showtime[]>;
  description: string;
  age: string;
  length?: number;
  format?: string;
  poster_link: string;
  backdrop_link?: string;
}

interface Props {
  movie: Movie;
  loading?: 'lazy' | 'eager';
}

const { movie, loading = 'lazy' } = Astro.props;

// Russian month names in genitive case
const monthNames = [
  'января', 'февраля', 'марта', 'апреля', 'мая', 'июня',
  'июля', 'августа', 'сентября', 'октября', 'ноября', 'декабря'
];

// Helper to format date label (always returns actual date, no "today")
const formatDateLabel = (dateKey: string): string => {
  const [day, month] = dateKey.split('.').map(Number);
  return `${day} ${monthNames[month - 1]}`;
};

const formatDurationBadge = (lengthInMinutes?: number): string | null => {
  if (!lengthInMinutes || lengthInMinutes <= 0) return null;

  const hours = Math.floor(lengthInMinutes / 60);
  const minutes = lengthInMinutes % 60;
  return `Длительность ${hours}:${String(minutes).padStart(2, '0')}`;
};

const formatMovieFormat = (rawFormat?: string): string | null => {
  if (!rawFormat) return null;

  const normalized = rawFormat.trim().toUpperCase();
  if (normalized !== '2D' && normalized !== '3D') return null;
  return normalized;
};

// Server-side: Just prepare all schedule entries, no filtering
const scheduleEntries = Object.entries(movie.times)
  .map(([dateKey, showtimes]) => ({
    dateKey,
    label: formatDateLabel(dateKey),
    times: showtimes
  }))
  .sort((a, b) => {
    const [dayA, monthA] = a.dateKey.split('.').map(Number);
    const [dayB, monthB] = b.dateKey.split('.').map(Number);
    return monthA !== monthB ? monthA - monthB : dayA - dayB;
  });

const durationBadge = formatDurationBadge(movie.length);
const movieFormat = formatMovieFormat(movie.format);

// Generate unique ID for description element
const descriptionId = `desc-${crypto.randomUUID().slice(0, 8)}`;
---

<article class="movie-card">
  <div class="poster">
    <Image src={movie.poster_link || fallback } fetchpriority={loading == "eager" ? "high" : "auto"} alt={movie.name} loading={loading} inferSize={true} class:list={[{ notForKids: movie.age == "18+" }]} />
  </div>

  <div class="content">
    <div class="header">
      <h2 class="title">{movie.name}</h2>
      <div class="header-row">
        <span class="age-badge" data-age={movie.age}>{movie.age}</span>
        {durationBadge && <span class="length-badge">{durationBadge}</span>}
        {movieFormat && <span class="format-badge" data-format={movieFormat}>{movieFormat}</span>}
        {movie.poster_link && movie.poster_link !== "" && (
          <a
            href={`https://www.youtube.com/results?search_query=${encodeURIComponent(movie.name + " трейлер")}`}
            target="_blank"
            rel="noopener noreferrer"
            class="trailer-btn"
          >
            🎬 Трейлер
          </a>
        )}
      </div>
    </div>

    <div class="description collapsed" id={descriptionId}>
      {movie.description}
    </div>
    <button class="read-more-btn" data-read-more={descriptionId}>
      Читать далее
    </button>

    <div class="schedule-container">
      {scheduleEntries.map((entry) => (
        <div class="schedule" data-date={entry.dateKey}>
          <span class="schedule-label">{entry.label}:</span>
          {entry.times.map((showtime) => (
            <span
              class="time-slot"
              data-timestamp={showtime.timestamp}
            >
              {showtime.time}
            </span>
          ))}
        </div>
      ))}
    </div>
  </div>
</article>

<style>
  .movie-card {
    display: flex;
    flex-direction: row;
    gap: 1rem;
    background: var(--color-card-bg);
    border-radius: 8px;
    overflow: hidden;
  }

  .poster {
    flex-shrink: 0;
    width: 40%;
    height: 180px;
    overflow: hidden;
  }

  @media (min-width: 768px) {
    .poster {
      width: 200px;
      height: auto;
      aspect-ratio: 2 / 3;
    }
  }

  .poster img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .content {
    padding: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    flex: 1;
  }

  @media (min-width: 768px) {
    .content {
      padding: 1rem;
      gap: 0.75rem;
    }
  }

  .header {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  @media (min-width: 768px) {
    .header {
      gap: 0.5rem;
    }
  }

  .header-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .title {
    text-transform: uppercase;
    font-weight: bold;
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.2;
  }

  @media (min-width: 768px) {
    .title {
      font-size: 1.25rem;
    }
  }

  .age-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.875rem;
    width: fit-content;
  }

  /* Age rating colors */
  .age-badge[data-age="0+"] {
    background: #ffffff;
    color: #000000;
  }

  .age-badge[data-age="6+"] {
    background: #10b981;
    color: #ffffff;
  }

  .age-badge[data-age="12+"] {
    background: #fbbf24;
    color: #000000;
  }

  .age-badge[data-age="16+"] {
    background: #f97316;
    color: #ffffff;
  }

  .age-badge[data-age="18+"] {
    background: #dc2626;
    color: #ffffff;
  }

  .length-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.875rem;
    width: fit-content;
    background: rgba(255, 255, 255, 0.14);
    color: var(--color-text);
  }

  .format-badge {
    display: inline-block;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-weight: 700;
    font-size: 0.875rem;
    width: fit-content;
    letter-spacing: 0.02em;
  }

  .format-badge[data-format="2D"] {
    background: #2563eb;
    color: #ffffff;
  }

  .format-badge[data-format="3D"] {
    background: #7c3aed;
    color: #ffffff;
  }

  .trailer-btn {
    display: inline-block;
    background-color: #302a20;
    color: #ffffff;
    padding: 0.25rem 0.75rem;
    border-radius: 12px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
    white-space: nowrap;
  }

  .trailer-btn:active {
    transform: translateY(0);
  }

  .description {
    color: var(--color-text-dim);
    line-height: 1.6;
    max-height: 1000px;
    transition: max-height 0.3s ease;
    overflow: hidden;
  }

  .description.collapsed {
    max-height: 3.6em;
  }

  .read-more-btn {
    background: none;
    border: none;
    color: var(--color-accent);
    cursor: pointer;
    text-decoration: underline;
    padding: 0;
    font-size: 0.875rem;
    text-align: left;
    width: fit-content;
  }

  .read-more-btn:hover {
    opacity: 0.8;
  }

  .schedule-container {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .schedule {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .schedule-label {
    font-weight: 600;
    text-transform: uppercase;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .time-slot {
    background: rgba(255, 255, 255, 0.1);
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.875rem;
    color: var(--color-text);
  }

  .notForKids {
    filter: blur(10px) grayscale(100%);
  }
</style>

<script>
  // Handle description expand/collapse
  document.querySelectorAll('[data-read-more]').forEach((button) => {
    button.addEventListener('click', (e) => {
      const target = e.currentTarget as HTMLButtonElement;
      const descId = target.dataset.readMore;
      const description = document.getElementById(descId!);

      if (description) {
        const isCollapsed = description.classList.toggle('collapsed');
        target.textContent = isCollapsed ? 'Читать далее' : 'Скрыть';
      }
    });
  });
</script>
