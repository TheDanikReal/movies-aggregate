---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.astro';
import LastUpdatedBadge from '../components/LastUpdatedBadge.astro';
import scheduleData from '../../tools/schedule.json';

// Get first few movies for testing
const testMovies = scheduleData.movies
---

<Layout title="КиноСлон">
  <main class="container">
    <h1>Аггрегатор кинотеатров в Слониме, обновляется по средам в 20:00 (неофициальный сайт, для официального сайта слонимского РДК <a href="http://kinoteatr.megamag.by/index.php?cPath=353299">нажмите сюда</a>)</h1>

    <div class="header-section">
      <LastUpdatedBadge updatedAt={scheduleData.updated_at} />
    </div>

    <div class="movies-grid">
      {testMovies.map((movie) => (
        <MovieCard movie={movie} />
      ))}
    </div>
  </main>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    margin-bottom: 1rem;
    color: var(--color-text);
    font-size: 2rem;
  }

  .header-section {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .header-section {
      justify-content: flex-start;
    }
  }

  .movies-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .movies-grid {
      gap: 3rem;
    }
  }
</style>
