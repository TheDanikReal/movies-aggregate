---
import Layout from '../layouts/Layout.astro';
import MovieCard from '../components/MovieCard.astro';
import LastUpdatedBadge from '../components/LastUpdatedBadge.astro';
import scheduleData from '../../tools/schedule.json';

const sourceMovies = scheduleData.movies

const movies = sourceMovies.sort((a, b) => b.rating - a.rating)
---

<Layout title="Кинотеатр Слоним - РДК, расписание кино | КиноСлон">
  <main class="container">
    <h1>КиноСлон - расписание слонимского РДК</h1>

    <div class="header-section">
      <LastUpdatedBadge updatedAt={scheduleData.updated_at} />
    </div>

    <div class="movies-grid">
      {movies.map((movie, index) => (
        <MovieCard movie={movie} loading={index < 2 ? 'eager' : 'lazy'} />
      ))}
    </div>
  </main>

  <footer class="footer">
    <div class="container">
      <p>
        Неофициальный аггрегатор кинотеатров в Слониме, обновляется по средам в 20:00.
        Для официального сайта слонимского РДК <a href="http://kinoteatr.megamag.by/index.php?cPath=353299">нажмите сюда</a>.
      </p>
    </div>
  </footer>
</Layout>

<style>
  .container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2rem 1rem;
  }

  h1 {
    margin-bottom: 1rem;
    color: var(--color-text);
    font-size: 2rem;
    text-align: center;
  }

  @media (min-width: 768px) {
    h1 {
      text-align: left;
    }
  }

  .header-section {
    display: flex;
    justify-content: center;
    margin-bottom: 2rem;
  }

  @media (min-width: 768px) {
    .header-section {
      justify-content: flex-start;
    }
  }

  .movies-grid {
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  @media (min-width: 1024px) {
    .movies-grid {
      gap: 3rem;
    }
  }

  .footer {
    margin-top: 3rem;
    padding: 2rem 0;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    background: rgba(0, 0, 0, 0.3);
  }

  .footer p {
    color: var(--color-text-dim);
    font-size: 0.875rem;
    line-height: 1.5;
    text-align: center;
    margin: 0;
  }

  .footer a {
    color: var(--color-accent);
    text-decoration: underline;
  }

  .footer a:hover {
    color: #ef4444;
  }
</style>
